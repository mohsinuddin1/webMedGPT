---
export interface Props {
  type: 'homepage' | 'article' | 'legal';
  title?: string;
  description?: string;
  publishedDate?: string;
  modifiedDate?: string;
  author?: string;
  image?: string;
  faqs?: Array<{ question: string; answer: string }>;
  about?: string[];
  mentions?: string[];
}

const { type, title, description, publishedDate, modifiedDate, author, image, faqs, about = [], mentions = [] } = Astro.props;
const siteUrl = 'https://medgptai.droploop.in';
const pageUrl = new URL(Astro.url.pathname, siteUrl).toString();

// Organization schema (always present)
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'PureScan AI',
  url: siteUrl,
  logo: `${siteUrl}/favicon.svg`,
  contactPoint: {
    '@type': 'ContactPoint',
    email: 'purescanai@outlook.com',
    contactType: 'customer support',
  },
};

// SoftwareApplication schema
const appSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'MedGPT — AI Health Assistant',
  operatingSystem: 'Android',
  applicationCategory: 'HealthApplication',
  description: 'AI-powered health companion. Analyze medical reports, blood tests, understand medications, explore symptoms, and prepare for doctor visits.',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  installUrl: 'https://play.google.com/store/apps/details?id=com.medgptai.app',
  author: {
    '@type': 'Organization',
    name: 'PureScan AI',
  },
};

// WebSite schema (homepage only)
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'MedGPT',
  url: siteUrl,
  publisher: {
    '@type': 'Organization',
    name: 'PureScan AI',
  },
};

// Helper to parse 'Type: Name' strings (e.g. 'MedicalCondition: Keratosis Pilaris')
const parseEntity = (item: string) => {
  const parts = item.split(':');
  if (parts.length === 2) {
    return { '@type': parts[0].trim(), name: parts[1].trim() };
  }
  return { '@type': 'Thing', name: item };
};

// Article schema
const articleSchema = publishedDate ? {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: description,
  datePublished: publishedDate,
  dateModified: modifiedDate || publishedDate,
  author: {
    '@type': 'Organization',
    name: author || 'MedGPT Team',
  },
  publisher: {
    '@type': 'Organization',
    name: 'PureScan AI',
    logo: {
      '@type': 'ImageObject',
      url: `${siteUrl}/favicon.svg`,
    },
  },
  isAccessibleForFree: true,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': pageUrl,
  },
  ...(about.length > 0 && { about: about.map(parseEntity) }),
  ...(mentions.length > 0 && { mentions: mentions.map(parseEntity) }),
  image: image ? `${siteUrl}${image}` : `${siteUrl}/og-image.png`,
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['.prose h1', '.prose h2', '.blog-post__short-answer', '.prose p:first-of-type'],
  },
} : null;

// MedicalWebPage (for health articles)
const medicalWebPageSchema = type === 'article' ? {
  '@context': 'https://schema.org',
  '@type': 'MedicalWebPage',
  name: title,
  url: pageUrl,
  description: description,
  lastReviewed: modifiedDate || publishedDate,
  medicalAudience: {
    '@type': 'PatientAudience',
  },
} : null;

// FAQ schema
const faqSchema = faqs && faqs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(faq => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
} : null;

// BreadcrumbList
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: siteUrl,
    },
    ...(type !== 'homepage' ? [{
      '@type': 'ListItem',
      position: 2,
      name: title,
      item: pageUrl,
    }] : []),
  ],
};

const schemas = [
  organizationSchema,
  breadcrumbSchema,
  ...(type === 'homepage' ? [appSchema, websiteSchema] : []),
  ...(articleSchema ? [articleSchema] : []),
  ...(medicalWebPageSchema ? [medicalWebPageSchema] : []),
  ...(faqSchema ? [faqSchema] : []),
];
---

{schemas.map(schema => (
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
))}
