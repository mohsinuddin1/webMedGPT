---
import { getCollection } from 'astro:content';
import { getUITranslation } from '../utils/uiTranslations';

export interface Props {
  currentTitle: string;
  tags: string[];
  lang?: string;
}

const { currentTitle, tags, lang = 'en' } = Astro.props;

const allBlogs = await getCollection('blog');

// Filter blogs by language
const languagePrefix = lang === 'en' ? 'en/' : `${lang}/`;
const localizedBlogs = allBlogs.filter((blog) => blog.id.startsWith(languagePrefix));

// Exclude current blog and calculate similarity score
const similarBlogs = localizedBlogs
  .filter((blog) => blog.data.title !== currentTitle)
  .map((blog) => {
    // Count how many tags match
    const commonTags = blog.data.tags.filter((tag) => tags.includes(tag)).length;
    return { ...blog, commonTags };
  })
  .sort((a, b) => {
    // Sort by common tags first
    if (b.commonTags !== a.commonTags) {
      return b.commonTags - a.commonTags;
    }
    // Fallback to latest publication date
    return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
  })
  .slice(0, 3); // Get top 3

const langPrefixUrl = lang === 'en' ? '' : `/${lang}`;
---

{similarBlogs.length > 0 && (
  <section class="similar-blogs">
    <h2>{getUITranslation(lang, 'similarBlogs')}</h2>
    <div class="similar-blogs__grid">
      {similarBlogs.map((blog) => {
        // Construct the correct URL slug
        const slug = blog.id.replace(languagePrefix, '');
        return (
          <a href={`${langPrefixUrl}/blog/${slug}`} class="similar-blogs__card">
            {blog.data.image && (
              <div class="similar-blogs__image">
                <img src={blog.data.image} alt={blog.data.imageAlt || blog.data.title} loading="lazy" />
              </div>
            )}
            <div class="similar-blogs__content">
              <h3>{blog.data.title}</h3>
              <p class="similar-blogs__meta">
                {blog.data.readingTime}
              </p>
            </div>
          </a>
        );
      })}
    </div>
  </section>
)}

<style>
  .similar-blogs {
    margin: var(--space-12) 0;
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  .similar-blogs h2 {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-6);
    color: var(--color-text-primary);
    font-weight: 700;
  }

  .similar-blogs__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-6);
  }

  .similar-blogs__card {
    display: flex;
    flex-direction: column;
    border-radius: var(--radius-lg);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    overflow: hidden;
    transition: transform var(--transition-fast), box-shadow var(--transition-fast);
    text-decoration: none;
    color: inherit;
  }

  .similar-blogs__card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-color: var(--color-accent);
  }

  .similar-blogs__image {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-bg-subtle);
  }

  .similar-blogs__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .similar-blogs__card:hover .similar-blogs__image img {
    transform: scale(1.05);
  }

  .similar-blogs__content {
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    gap: var(--space-2);
  }

  .similar-blogs__content h3 {
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-text-primary);
    line-height: 1.4;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .similar-blogs__meta {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-top: auto;
  }
</style>
