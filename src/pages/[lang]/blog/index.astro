---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getUITranslation } from '../../../utils/uiTranslations';
import { getCollection } from 'astro:content';
import { slugMap } from '../../../utils/slugMap';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  
  // Extract all unique languages from the posts (excluding English as it's the default)
  const languages = new Set<string>();
  posts.forEach(post => {
    if (!post.id.startsWith('en/')) {
      const lang = post.id.split('/')[0];
      languages.add(lang);
    }
  });

  return Array.from(languages).map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params;
const allPosts = await getCollection('blog');

// Get all posts for this language, and sort by date
const posts = allPosts
  .filter(post => post.id.startsWith(`${lang}/`))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// We can look up translation titles/descriptions based on language if needed,
// but let's use the english fallbacks or a generic one for now.
const title = "Health Blog — MedGPT AI Health Assistant";
const description = "Expert health guides, medical report tips, and medication safety information.";

---

<BaseLayout
  title={title}
  description={description}
  schemaType="legal"
  lang={lang}
  showLanguageSwitcher={true}
>
  <div class="blog-index">
    <div class="container">
      <div class="blog-index__header">
        <nav class="blog-index__breadcrumb" aria-label="Breadcrumb">
          <a href="/">{getUITranslation(lang, 'home')}</a>
          <span aria-hidden="true">→</span>
          <span>{getUITranslation(lang, 'blog')}</span>
        </nav>
        <span class="label">{getUITranslation(lang, 'healthResources')}</span>
        <h1 class="heading-section" style="text-align: start;">
          {getUITranslation(lang, 'healthGuidesTitle1')}<br/><span class="text-gradient">{getUITranslation(lang, 'healthGuidesTitle2')}</span>
        </h1>
        <p class="subtitle">{getUITranslation(lang, 'healthGuidesSubtitle')}</p>
      </div>

      <!-- Posts Grid -->
      <div class="grid-2">
        {posts.map((post) => (
          <a href={`/${lang}/blog/${post.id.replace(`${lang}/`, '')}`} class="blog-card" id={`blog-card-${post.id.replace(`${lang}/`, '')}`}>
            <div class="blog-card__image">
              {post.data.image ? (
                <img src={post.data.image} alt={post.data.imageAlt || post.data.title} loading="lazy" />
              ) : (
                <div class="blog-card__image-placeholder" style={`background: linear-gradient(135deg, var(--color-accent-glow), rgba(14, 165, 233, 0.15));`}>
                  <span class="blog-card__image-icon" style="color: var(--color-accent); display: flex; align-items: center; justify-content: center;" aria-hidden="true">
                    {post.data.tags.includes('Blood Tests') ? (
                      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/></svg>
                    ) : (
                      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m10.5 20.5 10-10a4.95 4.95 0 1 0-7-7l-10 10a4.95 4.95 0 1 0 7 7Z"/><path d="m8.5 8.5 7 7"/></svg>
                    )}
                  </span>
                </div>
              )}
            </div>
            <div class="blog-card__body">
              <span class="blog-card__tag">{post.data.tags[0]}</span>
              <h2 class="blog-card__title">{post.data.title}</h2>
              <p class="blog-card__excerpt">{post.data.description}</p>
              <div class="blog-card__meta">
                <span>{post.data.author}</span>
                <span>•</span>
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString(lang, { month: 'short', day: 'numeric', year: 'numeric' })}
                </time>
                <span>•</span>
                <span>{post.data.readingTime}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .blog-index {
    padding-top: calc(var(--header-height) + var(--space-12));
    padding-bottom: var(--space-24);
  }

  .blog-index__header {
    margin-bottom: var(--space-12);
  }

  .blog-index__breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
  }

  .blog-index__breadcrumb a {
    color: var(--color-text-secondary);
    transition: color var(--transition-fast);
  }

  .blog-index__breadcrumb a:hover {
    color: var(--color-accent);
  }

  .blog-card__image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .blog-card__image-emoji {
    font-size: 3rem;
  }
</style>
