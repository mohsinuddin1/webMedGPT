---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout
  title="Health Blog — MedGPT AI Health Assistant"
  description="Expert health guides, medical report tips, and medication safety information. Learn how to read blood tests, understand side effects, and make informed health decisions."
  schemaType="legal"
>
  <div class="blog-index">
    <div class="container">
      <!-- Header -->
      <div class="blog-index__header">
        <nav class="blog-index__breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span aria-hidden="true">→</span>
          <span>Blog</span>
        </nav>
        <span class="label">Health Resources</span>
        <h1 class="heading-section" style="text-align: left;">Health Guides &<br/><span class="text-gradient">Expert Insights</span></h1>
        <p class="subtitle">Evidence-based health articles to help you understand medical reports, medications, and wellness — powered by the MedGPT team.</p>
      </div>

      <!-- Posts Grid -->
      <div class="grid-2">
        {posts.map((post) => (
          <a href={`/blog/${post.id}`} class="blog-card" id={`blog-card-${post.id}`}>
            <div class="blog-card__image">
              <div class="blog-card__image-placeholder" style={`background: linear-gradient(135deg, var(--color-accent-glow), rgba(14, 165, 233, 0.15));`}>
                <span class="blog-card__image-icon" style="color: var(--color-accent); display: flex; align-items: center; justify-content: center;" aria-hidden="true">
                  {post.data.tags.includes('Blood Tests') ? (
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/></svg>
                  ) : (
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m10.5 20.5 10-10a4.95 4.95 0 1 0-7-7l-10 10a4.95 4.95 0 1 0 7 7Z"/><path d="m8.5 8.5 7 7"/></svg>
                  )}
                </span>
              </div>
            </div>
            <div class="blog-card__body">
              <span class="blog-card__tag">{post.data.tags[0]}</span>
              <h2 class="blog-card__title">{post.data.title}</h2>
              <p class="blog-card__excerpt">{post.data.description}</p>
              <div class="blog-card__meta">
                <span>{post.data.author}</span>
                <span>•</span>
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                </time>
                <span>•</span>
                <span>{post.data.readingTime}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .blog-index {
    padding-top: calc(var(--header-height) + var(--space-12));
    padding-bottom: var(--space-24);
  }

  .blog-index__header {
    margin-bottom: var(--space-12);
  }

  .blog-index__breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
  }

  .blog-index__breadcrumb a {
    color: var(--color-text-secondary);
    transition: color var(--transition-fast);
  }

  .blog-index__breadcrumb a:hover {
    color: var(--color-accent);
  }

  .blog-card__image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .blog-card__image-emoji {
    font-size: 3rem;
  }
</style>
