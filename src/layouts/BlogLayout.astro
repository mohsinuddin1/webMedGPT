---
import BaseLayout from '../layouts/BaseLayout.astro';
import DownloadCTA from '../components/DownloadCTA.astro';
import SimilarBlogs from '../components/SimilarBlogs.astro';
import MedicalCitations from '../components/MedicalCitations.astro';
import { getUITranslation } from '../utils/uiTranslations';

export interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  author: string;
  image?: string;
  imageAlt?: string;
  readingTime: string;
  tags: string[];
  shortAnswer?: string;
  about?: string[];
  mentions?: string[];
  sources?: Array<{ name: string; url: string; description?: string }>;
  lang?: string;
  dir?: 'ltr' | 'rtl';
}

const { title, description, pubDate, updatedDate, author, image, imageAlt, readingTime, tags, shortAnswer, about, mentions, sources = [], lang = 'en', dir } = Astro.props;

const formattedPubDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdatedDate = updatedDate?.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout
  title={title}
  description={description}
  ogType="article"
  publishedTime={pubDate.toISOString()}
  modifiedTime={updatedDate?.toISOString() || pubDate.toISOString()}
  author={author}
  schemaType="article"
  image={image}
  about={about}
  mentions={mentions}
  lang={lang}
  dir={dir}
  showLanguageSwitcher={true}
>
  <article class="blog-post">
    <div class="container container--blog">
      <!-- Breadcrumbs -->
      <nav class="blog-post__breadcrumb" aria-label="Breadcrumb">
        <a href="/">{getUITranslation(lang, 'home')}</a>
        <span aria-hidden="true">→</span>
        <a href={`/${lang === 'en' ? '' : lang + '/'}blog`.replace('//', '/')}>{getUITranslation(lang, 'blog')}</a>
        <span aria-hidden="true">→</span>
        <span>{title}</span>
      </nav>

      <!-- Header -->
      <header class="blog-post__header">
        <div class="blog-post__tags">
          {tags.map(tag => (
            <span class="badge">{tag}</span>
          ))}
        </div>
        <h1 class="blog-post__title">{title}</h1>
        <p class="blog-post__excerpt">{description}</p>
        <div class="blog-post__meta">
          <span>{getUITranslation(lang, 'by')} {author}</span>
          <span>•</span>
          <time datetime={pubDate.toISOString()}>{formattedPubDate}</time>
          <span>•</span>
          <span>{readingTime}</span>
        </div>
        {formattedUpdatedDate && (
          <p class="blog-post__updated">{getUITranslation(lang, 'updated')} {formattedUpdatedDate}</p>
        )}
      </header>
      
      {image && (
        <div class="blog-post__hero-image">
          <img src={image} alt={imageAlt || title} />
        </div>
      )}

      <!-- Content -->
      <div class="prose">
        {shortAnswer && (
          <p class="blog-post__short-answer">
            <strong>Short answer:</strong> {shortAnswer}
          </p>
        )}
        <slot />
      </div>

      <!-- Sources & Citations -->
      <MedicalCitations lang={lang} sources={sources} />

      <!-- Similar Blogs -->
      <SimilarBlogs currentTitle={title} tags={tags} lang={lang} />

      <!-- CTA -->
      <aside class="blog-post__cta">
        <h3>{getUITranslation(lang, 'tryMedGPTFree')}</h3>
        <p>{getUITranslation(lang, 'tryMedGPTDesc')}</p>
        <DownloadCTA variant="primary" utmMedium="blog-post" />
      </aside>

      <!-- Back to Blog -->
      <nav class="blog-post__nav">
        <a href={`/${lang === 'en' ? '' : lang + '/'}blog`.replace('//', '/')} class="btn btn--secondary">{getUITranslation(lang, 'backToBlog')}</a>
      </nav>
    </div>
  </article>
</BaseLayout>

<style>
  .blog-post {
    padding-top: calc(var(--header-height) + var(--space-12));
    padding-bottom: var(--space-24);
  }

  .blog-post__breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-8);
  }

  .blog-post__breadcrumb a {
    color: var(--color-text-secondary);
    transition: color var(--transition-fast);
  }

  .blog-post__breadcrumb a:hover {
    color: var(--color-accent);
  }

  .blog-post__header {
    margin-bottom: var(--space-12);
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--color-border);
  }

  .blog-post__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .blog-post__title {
    font-size: var(--text-4xl);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: var(--space-4);
  }

  .blog-post__excerpt {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: var(--space-4);
  }

  .blog-post__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .blog-post__short-answer {
    font-size: var(--text-lg);
    line-height: 1.6;
    color: var(--color-text-primary);
    background: var(--color-bg-subtle);
    padding: var(--space-4) var(--space-6);
    border-left: 4px solid var(--color-accent);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    margin-bottom: var(--space-8);
  }

  .blog-post__updated {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-top: var(--space-2);
  }

  .blog-post__cta {
    margin: var(--space-12) 0;
    padding: var(--space-8);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-align: center;
  }

  .blog-post__cta h3 {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-2);
    color: var(--color-text-primary);
  }

  .blog-post__cta p {
    color: var(--color-text-secondary);
    margin-bottom: var(--space-5);
    font-size: var(--text-base);
  }

  .blog-post__nav {
    margin-top: var(--space-8);
  }

  .blog-post__hero-image {
    margin-top: var(--space-8);
    margin-bottom: var(--space-12);
    border-radius: var(--radius-xl);
    overflow: hidden;
    aspect-ratio: 21 / 9;
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-lg);
  }
  
  .blog-post__hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>
