---
import BaseLayout from '../layouts/BaseLayout.astro';
import DownloadCTA from '../components/DownloadCTA.astro';

export interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  author: string;
  image?: string;
  imageAlt?: string;
  readingTime: string;
  tags: string[];
}

const { title, description, pubDate, updatedDate, author, image, imageAlt, readingTime, tags } = Astro.props;

const formattedPubDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdatedDate = updatedDate?.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout
  title={title}
  description={description}
  ogType="article"
  publishedTime={pubDate.toISOString()}
  modifiedTime={updatedDate?.toISOString() || pubDate.toISOString()}
  author={author}
  schemaType="article"
  image={image}
>
  <article class="blog-post">
    <div class="container container--blog">
      <!-- Breadcrumbs -->
      <nav class="blog-post__breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">→</span>
        <a href="/blog">Blog</a>
        <span aria-hidden="true">→</span>
        <span>{title}</span>
      </nav>

      <!-- Header -->
      <header class="blog-post__header">
        <div class="blog-post__tags">
          {tags.map(tag => (
            <span class="badge">{tag}</span>
          ))}
        </div>
        <h1 class="blog-post__title">{title}</h1>
        <p class="blog-post__excerpt">{description}</p>
        <div class="blog-post__meta">
          <span>By {author}</span>
          <span>•</span>
          <time datetime={pubDate.toISOString()}>{formattedPubDate}</time>
          <span>•</span>
          <span>{readingTime}</span>
        </div>
        {formattedUpdatedDate && (
          <p class="blog-post__updated">Updated: {formattedUpdatedDate}</p>
        )}
      </header>

      <!-- Content -->
      <div class="prose">
        <slot />
      </div>

      <!-- CTA -->
      <aside class="blog-post__cta">
        <h3>Try MedGPT Free</h3>
        <p>Get instant AI-powered analysis of your medical reports and health questions.</p>
        <DownloadCTA variant="primary" utmMedium="blog-post" />
      </aside>

      <!-- Back to Blog -->
      <nav class="blog-post__nav">
        <a href="/blog" class="btn btn--secondary">← Back to Blog</a>
      </nav>
    </div>
  </article>
</BaseLayout>

<style>
  .blog-post {
    padding-top: calc(var(--header-height) + var(--space-12));
    padding-bottom: var(--space-24);
  }

  .blog-post__breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-8);
  }

  .blog-post__breadcrumb a {
    color: var(--color-text-secondary);
    transition: color var(--transition-fast);
  }

  .blog-post__breadcrumb a:hover {
    color: var(--color-accent);
  }

  .blog-post__header {
    margin-bottom: var(--space-12);
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--color-border);
  }

  .blog-post__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .blog-post__title {
    font-size: var(--text-4xl);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: var(--space-4);
  }

  .blog-post__excerpt {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: var(--space-4);
  }

  .blog-post__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .blog-post__updated {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-top: var(--space-2);
  }

  .blog-post__cta {
    margin: var(--space-12) 0;
    padding: var(--space-8);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-align: center;
  }

  .blog-post__cta h3 {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-2);
    color: var(--color-text-primary);
  }

  .blog-post__cta p {
    color: var(--color-text-secondary);
    margin-bottom: var(--space-5);
    font-size: var(--text-base);
  }

  .blog-post__nav {
    margin-top: var(--space-8);
  }
</style>
